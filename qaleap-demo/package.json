{
  "name": "qaleap-demo",
  "version": "1.0.0",
  "private": true,
  "description": "QA Leap demo Task Manager — a stable showcase target for automated testing (UI, API, visual).",
  "scripts": {
    "build": "vite build --config client/vite.config.ts",
    "start": "npm run build && tsx server/src/index.ts",
    "server": "tsx server/src/index.ts",
    "dev": "concurrently -k -n API,WEB -c cyan,magenta \"tsx watch server/src/index.ts\" \"vite --config client/vite.config.ts\""
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.2",
    "concurrently": "^9.0.1",
    "express": "^4.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "tsx": "^4.19.1",
    "vite": "^5.4.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.16.11",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.5.4"
  }
}
