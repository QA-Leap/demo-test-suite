# Copy this file to `.env` and adjust as needed:  cp .env.example .env
# `.env` is git-ignored and never committed.

# ── Demo app under test ──────────────────────────────────────────────
# Base URL of the running Task Manager demo.
# Keep it on localhost to let Playwright auto-start (and reuse) the demo,
# or point it at a deployed environment to run against that instead.
BASE_URL=http://localhost:3000

# Path to the bundled demo app, used to auto-start it locally (it ships in this repo).
DEMO_DIR=./qaleap-demo

# ── Test credentials ─────────────────────────────────────────────────
# The demo app's public sandbox login. In a real project these would come from a
# secrets manager / CI secrets — never committed — and the code fallbacks removed.
DEMO_EMAIL=demo@qaleap.com
DEMO_PASSWORD=Demo123

# ── Execution (optional) ─────────────────────────────────────────────
# Parallel worker count; overrides the default. Also settable via `--workers`.
# WORKERS=4
